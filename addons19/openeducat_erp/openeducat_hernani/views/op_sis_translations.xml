<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ================================================================
             IRAKASLEAK (op.faculty)
        ================================================================ -->

        <record id="view_op_faculty_tree_eu" model="ir.ui.view">
            <field name="name">op.faculty.tree.eu</field>
            <field name="model">op.faculty</field>
            <field name="inherit_id" ref="openeducat_core.view_op_faculty_tree"/>
            <field name="priority" eval="12"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="attributes">
                    <attribute name="string">Irakasleak</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_op_faculty_form_eu" model="ir.ui.view">
            <field name="name">op.faculty.form.eu</field>
            <field name="model">op.faculty</field>
            <field name="inherit_id" ref="openeducat_core.view_op_faculty_form"/>
            <field name="priority" eval="12"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="attributes">
                    <attribute name="string">Irakaslea</attribute>
                </xpath>
                <xpath expr="//widget[@name='web_ribbon']" position="attributes">
                    <attribute name="title">Artxibatua</attribute>
                </xpath>
                <page name="personal_information" position="attributes">
                    <attribute name="string">Informazio pertsonala</attribute>
                </page>
                <page name="subjects" position="attributes">
                    <attribute name="string">Moduluak</attribute>
                </page>
                <xpath expr="//label[@for='street']" position="attributes">
                    <attribute name="string">Helbidea</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_op_faculty_search_eu" model="ir.ui.view">
            <field name="name">op.faculty.search.eu</field>
            <field name="model">op.faculty</field>
            <field name="inherit_id" ref="openeducat_core.view_op_faculty_search"/>
            <field name="priority" eval="12"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="attributes">
                    <attribute name="string">Irakasleak</attribute>
                </xpath>
                <xpath expr="//group[@expand='0']" position="attributes">
                    <attribute name="string">Taldekatu...</attribute>
                </xpath>
                <filter name="blood_group" position="attributes">
                    <attribute name="string">Odol taldea</attribute>
                </filter>
                <filter name="nationality" position="attributes">
                    <attribute name="string">Nazionalitatea</attribute>
                </filter>
                <filter name="language" position="attributes">
                    <attribute name="string">Hizkuntza</attribute>
                </filter>
                <filter name="inactive" position="attributes">
                    <attribute name="string">Artxibatutakoak</attribute>
                </filter>
            </field>
        </record>

        <record id="openeducat_core.act_open_op_faculty_view" model="ir.actions.act_window">
            <field name="name">Irakasleak</field>
        </record>
        <record id="openeducat_core.act_open_op_faculty_view_2" model="ir.actions.act_window">
            <field name="name">Irakasleak</field>
        </record>


