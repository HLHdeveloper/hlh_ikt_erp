<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Formulario de op.subject: kode_jima + campos nuevos -->
        <record id="view_op_subject_form_hernani" model="ir.ui.view">
            <field name="name">op.subject.form.hernani</field>
            <field name="model">op.subject</field>
            <field name="inherit_id" ref="openeducat_core.view_op_subject_form"/>
            <field name="arch" type="xml">
                <form position="attributes">
                    <attribute name="js_class">subject_save_back_form</attribute>
                </form>
                <field name="code" position="after">
                    <field name="kode_jima"/>
                </field>
                <field name="type" position="attributes">
                    <attribute name="invisible">1</attribute>
                </field>
                <field name="grade_weightage" position="attributes">
                    <attribute name="invisible">1</attribute>
                </field>
                <xpath expr="//group[1]" position="after">
                    <group string="Informazio gehigarria">
                        <group>
                            <field name="batch_id" string="Taldea"/>
                            <field name="hizkuntza"/>
                            <field name="kurtsoa"/>
                            <field name="gela_orduak" string="Gela Orduak"/>
                            <field name="own_department_id" invisible="1"/>
                            <field name="mintegiko_irakaslea" string="Mintegiko irakaslea"
                                   domain="[('id', '!=', own_department_id)]"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="pt_pes" string="PT_PES"/>
                            <field name="pl" string="PL"/>
                            <field name="orduak"/>
                            <field name="banaketa_id" string="Aste Banaketa"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="rpt_total" string="RPT Total"/>
                            <field name="rpt_reala" string="RPT Reala"/>
                            <field name="rpt_zorretan" string="RPT Zorretan"/>
                            <field name="emandako_orduak" string="Emandako Orduak"/>
                            <field name="orduak_zorretan" string="Orduak Zorretan"/>
                            <field name="zikloko_orduak_enpresan" string="Zikloko Orduak Enpresan"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- Lista de op.subject: columnas exactas solicitadas -->
        <record id="view_op_subject_tree_hernani" model="ir.ui.view">
            <field name="name">op.subject.tree.hernani</field>
            <field name="model">op.subject</field>
            <field name="inherit_id" ref="openeducat_core.view_op_subject_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="replace">
                    <!-- Lista editable SOLO para 'Aste Banaketa'; el resto de
                         columnas son readonly y se editan en la ficha (botón
                         "Fitxa" para abrir el formulario del módulo). -->
                    <tree string="Moduluak" class="moduluak_list hlh-styled" editable="bottom">
                        <field name="name" column_invisible="1"/>
                        <field name="batch_id" column_invisible="1"/>
                        <button name="action_open_form" type="object" icon="fa-pencil-square-o"
                                string="Fitxa" class="btn-link"
                                help="Moduluaren fitxa ireki (eremu guztiak editatzeko)"/>
                        <field name="kode_jima" string="Kode Jima" readonly="1"/>
                        <field name="talde_kodea" string="Talde Kodea" readonly="1"/>
                        <field name="code" string="Modulu Kodea" readonly="1"/>
                        <field name="pt_pes" string="PT_PES" readonly="1"/>
                        <field name="pl" string="PL" readonly="1"/>
                        <field name="orduak" string="Orduak" class="text-start" readonly="1"/>
                        <field name="kurtsoa" string="Kurtsoa" readonly="1"/>
                        <field name="gela_orduak" string="Gela" class="text-start" readonly="1"/>
                        <field name="banaketa_id" string="Aste Banaketa"
                               domain="[('guztira', '=', gela_orduak)]"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="rpt_total" string="RPT Total" class="text-start" readonly="1"/>
                        <field name="rpt_reala" string="RPT Reala" class="text-start" readonly="1"/>
                        <field name="rpt_zorretan" string="RPT Zorretan" class="text-start" readonly="1"/>
                        <field name="emandako_orduak" string="Emandako Orduak" class="text-start" readonly="1"/>
                        <field name="orduak_zorretan" string="Orduak Zorretan" class="text-start" readonly="1"/>
                    </tree>
                </xpath>
            </field>
        </record>

        <!-- Búsqueda: code como campo por defecto (antes que name) -->
        <record id="view_op_subject_search_hernani" model="ir.ui.view">
            <field name="name">op.subject.search.hernani</field>
            <field name="model">op.subject</field>
            <field name="inherit_id" ref="openeducat_core.view_op_subject_search"/>
            <field name="arch" type="xml">
                <search position="replace">
                    <search string="Subject">
                        <field name="code"/>
                        <field name="name"/>
                        <field name="type"/>
                        <field name="own_department_id" string="Mintegia"/>
                        <newline/>
                        <group expand="0" string="Group By...">
                            <filter name="group_by_subject_type" string="Type" domain="[]"
                                    context="{'group_by':'type'}"/>
                            <filter name="group_by_mintegia" string="Mintegia" domain="[]"
                                    context="{'group_by':'own_department_id'}"/>
                            <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                        </group>
                        <!-- Filtro vertical izquierdo en cascada (igual que los
                             desplegables de Perfilazioak): MINTEGIA → ZIKLOA →
                             TALDEA. Al seleccionar un mintegi, el searchpanel
                             solo muestra sus zikloak (las categorías con 0
                             registros se ocultan); al elegir un zikloa, solo
                             sus taldeak. -->
                        <searchpanel>
                            <field name="own_department_id" string="Mintegia"
                                   enable_counters="1"/>
                            <field name="course_id" string="Zikloa"
                                   enable_counters="1"/>
                            <field name="batch_id" string="Taldea"
                                   enable_counters="1"/>
                        </searchpanel>
                    </search>
                </search>
            </field>
        </record>
    </data>
</odoo>
