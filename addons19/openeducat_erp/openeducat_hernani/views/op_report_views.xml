<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════
             1. IKASLEAK TALDEKA (Alumnos por grupo)
        ══════════════════════════════════════════════════════ -->

        <record id="view_report_batch_student_tree" model="ir.ui.view">
            <field name="name">op.report.batch.student.tree</field>
            <field name="model">op.report.batch.student</field>
            <field name="arch" type="xml">
                <tree string="Ikasleak taldeka" default_order="batch_name">
                    <field name="batch_name" string="Taldea"/>
                    <field name="student_count" string="Ikasle kop."/>
                </tree>
            </field>
        </record>

        <record id="view_report_batch_student_graph" model="ir.ui.view">
            <field name="name">op.report.batch.student.graph</field>
            <field name="model">op.report.batch.student</field>
            <field name="arch" type="xml">
                <graph string="Ikasleak taldeka" type="bar">
                    <field name="batch_name" type="row"/>
                    <field name="student_count" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="view_report_batch_student_pivot" model="ir.ui.view">
            <field name="name">op.report.batch.student.pivot</field>
            <field name="model">op.report.batch.student</field>
            <field name="arch" type="xml">
                <pivot string="Ikasleak taldeka">
                    <field name="batch_name" type="row"/>
                    <field name="student_count" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="act_report_batch_student" model="ir.actions.act_window">
            <field name="name">Ikasleak taldeka</field>
            <field name="res_model">op.report.batch.student</field>
            <field name="view_mode">tree,graph,pivot</field>
        </record>

