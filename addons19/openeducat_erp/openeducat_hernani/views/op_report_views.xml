        <!-- ══════════════════════════════════════════════════════
             5. IRAKASLE GREBA PARTE-HARTZAILEAK
             (Profesores con más bajas, orden descendente)
        ══════════════════════════════════════════════════════ -->

        <record id="view_report_faculty_greba_tree" model="ir.ui.view">
            <field name="name">op.report.faculty.greba.tree</field>
            <field name="model">op.report.faculty.greba</field>
            <field name="arch" type="xml">
                <tree string="Irakasleak greba kopuruaren arabera"
                      default_order="greba_count desc">
                    <field name="faculty_name" string="Irakaslea"/>
                    <field name="department_name" string="Mintegia"/>
                    <field name="greba_count" string="Greba kop."/>
