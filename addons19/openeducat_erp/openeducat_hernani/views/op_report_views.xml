            <field name="view_mode">tree,graph</field>
        </record>

        <!-- Client action del dashboard -->
        <record id="action_sis_dashboard" model="ir.actions.client">
            <field name="name">Txostenak</field>
            <field name="tag">sis_dashboard_action</field>
        </record>

    </data>
</odoo>
