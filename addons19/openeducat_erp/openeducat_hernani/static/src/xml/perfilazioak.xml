<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="openeducat_hernani.Perfilazioak">
        <div class="o_perfilazioak o_action">
            <div class="o_content p-3">

                <!-- Header + selectors -->
                <div class="pfz-header d-flex align-items-end gap-3 flex-wrap mb-3">
                    <h5 class="mb-0 text-uppercase fw-semibold text-muted me-2">Perfilazioak</h5>

                    <div class="pfz-selector">
                        <label class="form-label mb-0 small fw-semibold">Mintegia</label>
                        <select class="form-select form-select-sm" t-on-change="onMintegiChange">
                            <option value="">—</option>
                            <t t-foreach="state.mintegiak" t-as="m" t-key="m.id">
                                <option t-att-value="m.id"
                                        t-att-selected="state.selectedMintegi and state.selectedMintegi.id === m.id ? 'selected' : ''">
                                    <t t-esc="m.name"/>
                                </option>
                            </t>
                        </select>
                    </div>

                    <t t-if="state.zikloak.length">
                        <div class="pfz-selector">
                            <label class="form-label mb-0 small fw-semibold">Zikloa</label>
                            <select class="form-select form-select-sm" t-on-change="onZikloaChange">
                                <option value="">—</option>
                                <t t-foreach="state.zikloak" t-as="z" t-key="z.id">
                                    <option t-att-value="z.id">
                                        <t t-esc="z.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </t>

                    <t t-if="state.batches.length">
                        <div class="pfz-selector">
                            <label class="form-label mb-0 small fw-semibold">Taldea</label>
                            <select class="form-select form-select-sm" t-on-change="onBatchChange">
                                <option value="">—</option>
                                <t t-foreach="state.batches" t-as="b" t-key="b.id">
                                    <option t-att-value="b.id">
                                        <t t-esc="b.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </t>

                    <t t-if="state.loading">
                        <i class="fa fa-spinner fa-spin text-muted ms-2"/>
                    </t>
                </div>

                <!-- Main panels -->
                <t t-if="state.selectedMintegi">
                    <div class="pfz-panels d-flex gap-3 align-items-start">

                        <!-- Left: Irakasleak + Karguak -->
                        <div class="pfz-left card">
                            <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="fw-semibold small text-uppercase">Irakasleak</span>
                                    <span class="text-muted small ms-1">(klik = hautatu)</span>
                                    <span class="pfz-legend small ms-2">
                                        <span class="badge pfz-faculty-gela bg-info text-dark">Gela</span>
                                        <span class="badge pfz-faculty-hours bg-light text-dark ms-1">RPT</span>
                                    </span>
                                </div>
                                <button class="btn btn-sm btn-outline-secondary py-0 px-1"
                                        title="Irakasle inpertsonala sortu"
                                        t-on-click="() => this.createImpersonal()">
                                    <i class="fa fa-plus"/>
                                </button>
                            </div>
                            <div class="card-body p-0">

                                <!-- Teacher list -->
                                <div class="pfz-faculty-list">
                                    <t t-if="!state.irakasleak.length">
                                        <div class="text-muted small px-3 py-2">Irakaslerik ez.</div>
                                    </t>
                                    <t t-foreach="state.irakasleak" t-as="f" t-key="f.id">
                                        <t t-if="f.kidergoa === 'impersonala' and (f_index === 0 or state.irakasleak[f_index - 1].kidergoa !== 'impersonala')">
                                            <div class="pfz-separator-impersonal d-flex align-items-center gap-2 px-3 py-1">
                                                <hr class="flex-grow-1 my-0"/>
                                                <span class="text-muted" style="font-size:.7rem;white-space:nowrap">Inpertsonalak</span>
                                                <hr class="flex-grow-1 my-0"/>
                                            </div>
                                        </t>
                                        <div t-attf-class="pfz-faculty-row {{ state.selectedFaculty and state.selectedFaculty.id === f.id ? 'pfz-faculty-row--active' : '' }}"
                                             t-on-click="() => this.onFacultyClick(f)">
                                            <span t-attf-class="pfz-faculty-name {{ f.overload ? 'pfz-overload' : '' }}">
                                                <t t-esc="f.name"/>
                                            </span>
                                            <span class="badge pfz-faculty-gela bg-info text-dark" title="Gela orduak">
                                                <t t-esc="f.gela"/>
                                            </span>
                                            <span t-attf-class="badge pfz-faculty-hours {{ f.overload ? 'bg-warning text-dark' : 'bg-light text-dark' }}" title="RPT orduak">
                                                <t t-esc="this.formatH(f.orduak)"/>
                                            </span>
                                            <button class="btn btn-sm btn-link text-secondary p-0 ms-1 pfz-kargu-del pfz-clear-btn"
                                                    title="Plaza hustu"
                                                    t-on-click.stop="() => this.clearPerfilazio(f)">
                                                <i class="fa fa-eraser"/>
                                            </button>
                                            <t t-if="f.kidergoa === 'impersonala'">
                                                <button class="btn btn-sm btn-link text-danger p-0 ms-1 pfz-kargu-del"
                                                        t-on-click.stop="() => this.deleteImpersonal(f)">
                                                    <i class="fa fa-times"/>
                                                </button>
                                            </t>
                                        </div>
                                    </t>
                                </div>

                                <!-- Karguak section -->
                                <t t-if="state.selectedFaculty">
                                    <div class="pfz-kargu-section border-top px-2 pt-2 pb-2">
                                        <div class="small fw-semibold text-uppercase text-muted mb-2">
                                            Karguak —
                                            <span t-attf-class="{{ state.selectedFaculty.overload ? 'text-warning' : 'text-success' }}">
                                                <t t-esc="state.selectedFaculty.name"/>
                                            </span>
                                        </div>

                                        <t t-if="!state.karguak.length">
                                            <div class="text-muted small mb-1">Kargurik ez.</div>
                                        </t>

                                        <t t-foreach="state.karguak" t-as="k" t-key="k.id">
                                            <div class="pfz-kargu-row d-flex align-items-center gap-1 mb-1">
                                                <span class="pfz-kargu-name small" t-esc="k.code"/>
                                                <select class="form-control form-control-sm pfz-kargu-input"
                                                        t-on-change="(ev) => this.onKarguHoursChange(ev, k)">
                                                    <t t-foreach="this.rowKarguOptions(k)" t-as="h" t-key="h">
                                                        <option t-att-value="h"
                                                                t-att-selected="h === k.orduak ? 'selected' : ''">
                                                            <t t-esc="h"/>
                                                        </option>
                                                    </t>
                                                </select>
                                                <span class="small text-muted">h</span>
                                                <span class="small text-muted" t-attf-title="Kargu honen guztira: {{ k.kargu_rpt }}h">
                                                    / <t t-esc="k.kargu_rpt"/>
                                                </span>
                                                <button class="btn btn-sm btn-link text-danger p-0 pfz-kargu-del"
                                                        t-on-click.stop="() => this.removeKargu(k)">
                                                    <i class="fa fa-times"/>
                                                </button>
                                            </div>
                                        </t>

                                        <!-- Add kargu form -->
                                        <t t-if="!state.addingKargu">
                                            <button class="btn btn-sm btn-outline-secondary w-100 mt-1"
                                                    t-on-click="() => this.openAddKargu()">
                                                <i class="fa fa-plus me-1"/>Gehitu kargua
                                            </button>
                                        </t>
                                        <t t-else="">
                                            <div class="pfz-add-kargu mt-1">
                                                <select class="form-select form-select-sm mb-1"
                                                        t-on-change="onNewKarguSelect">
                                                    <option value="">Aukeratu kargua...</option>
                                                    <t t-foreach="state.allKarguak" t-as="ak" t-key="ak.id">
                                                        <option t-att-value="ak.id">
                                                            <t t-esc="ak.code"/>
                                                            (<t t-esc="ak.remaining"/>/<t t-esc="ak.rpt_total"/>h libre)
                                                        </option>
                                                    </t>
                                                </select>
                                                <t t-if="state.newKarguId">
                                                    <div class="small mb-1">
                                                        Libre:
                                                        <span t-attf-class="fw-semibold {{ state.newKarguRemaining > 0 ? 'text-success' : 'text-danger' }}">
                                                            <t t-esc="state.newKarguRemaining"/>h
                                                        </span>
                                                    </div>
                                                </t>
                                                <div class="d-flex gap-1 align-items-center">
                                                    <t t-if="state.newKarguId and state.newKarguRemaining > 0">
                                                        <select class="form-control form-control-sm flex-grow-1"
                                                                t-on-change="onNewKarguOrduak">
                                                            <option value="">Orduak...</option>
                                                            <t t-foreach="this.rangeOptions(state.newKarguRemaining)" t-as="h" t-key="h">
                                                                <option t-att-value="h"><t t-esc="h"/>h</option>
                                                            </t>
                                                        </select>
                                                        <button class="btn btn-sm btn-primary"
                                                                t-att-disabled="!state.newKarguOrduak ? 'disabled' : ''"
                                                                t-on-click="() => this.saveKargu()">
                                                            <i class="fa fa-check"/>
                                                        </button>
                                                    </t>
                                                    <t t-elif="state.newKarguId">
                                                        <span class="small text-danger flex-grow-1">
                                                            Ez dago ordu librerik.
                                                        </span>
                                                    </t>
                                                    <button class="btn btn-sm btn-outline-secondary"
                                                            t-on-click="() => this.cancelAddKargu()">
                                                        <i class="fa fa-times"/>
                                                    </button>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>

                            </div>
                        </div>

                        <!-- Right: Moduluak + Resumen -->
                        <div class="pfz-right flex-grow-1 d-flex flex-column gap-3">
                            <t t-if="!state.selectedBatch and !state.ingelesaMode">
                                <div class="text-muted text-center py-5">
                                    Aukeratu zikloa eta taldea moduluak ikusteko.
                                </div>
                            </t>
                            <t t-else="">
                                <div class="pfz-moduluak card">
                                    <div class="card-header py-2 px-3 d-flex align-items-center gap-2 flex-wrap">
                                        <span class="fw-semibold small text-uppercase">Moduluak</span>
                                        <t t-if="state.selectedBatch">
                                            <span class="badge bg-secondary">
                                                <t t-esc="state.selectedBatch.name"/>
                                            </span>
                                        </t>
                                        <t t-elif="state.ingelesaMode">
                                            <span class="badge bg-secondary">INGELESA — guztiak</span>
                                        </t>
                                        <t t-if="state.selectedFaculty">
                                            <span class="ms-auto small text-muted">Esleitua:</span>
                                            <span t-attf-class="badge {{ state.selectedFaculty.overload ? 'bg-warning text-dark' : 'bg-success' }}">
                                                <t t-esc="state.selectedFaculty.name"/>
                                                (<t t-esc="this.formatH(state.selectedFaculty.orduak)"/>)
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span class="ms-auto small text-muted">
                                                Hautatu irakasle bat ezkerreko panelean.
                                            </span>
                                        </t>
                                    </div>
                                    <div class="card-body p-0">
                                        <table class="table table-sm pfz-table mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Kodea</th>
                                                    <th>PT/PES</th>
                                                    <th>Orduak</th>
                                                    <th>Kurtsoa</th>
                                                    <th>Aste Ban.</th>
                                                    <th>Gela</th>
                                                    <th>RPT</th>
                                                    <th>Zorretan</th>
                                                    <th>Irakaslea</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="state.moduluak" t-as="m" t-key="m.id">
                                                    <tr t-attf-class="pfz-modulu-row
                                                        {{ m.faculty_id ? 'pfz-modulu--assigned' : 'pfz-modulu--free' }}
                                                        {{ state.selectedFaculty and m.faculty_id === state.selectedFaculty.id ? 'pfz-modulu--mine' : '' }}"
                                                        t-on-click="() => this.onModuluClick(m)">
                                                        <td class="fw-semibold"><t t-esc="m.code"/></td>
                                                        <td><t t-esc="m.pt_pes"/></td>
                                                        <td><t t-esc="m.orduak"/></td>
                                                        <td><t t-esc="m.kurtsoa"/></td>
                                                        <td><t t-esc="m.aste_banaketa"/></td>
                                                        <td><t t-esc="m.gela_orduak"/></td>
                                                        <td class="fw-semibold"><t t-esc="m.rpt_total"/></td>
                                                        <td><t t-esc="m.orduak_zorretan"/></td>
                                                        <td>
                                                            <t t-if="m.faculty_name">
                                                                <span class="badge bg-secondary pfz-assigned-badge">
                                                                    <t t-esc="m.faculty_name"/>
                                                                </span>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="text-muted small">—</span>
                                                            </t>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="!state.moduluak.length">
                                                    <tr>
                                                        <td colspan="9" class="text-center text-muted py-3 small">
                                                            Modulurik ez talde honetan.
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </t>
                        <!-- Resumen perfilazio -->
                        <t t-if="state.selectedFaculty">
                            <div class="pfz-moduluak card">
                                <div class="card-header py-2 px-3 d-flex align-items-center gap-2">
                                    <span class="fw-semibold small text-uppercase">Perfilazio Laburpena</span>
                                    <span t-attf-class="badge {{ state.selectedFaculty.overload ? 'bg-warning text-dark' : 'bg-success' }}">
                                        <t t-esc="state.selectedFaculty.name"/>
                                        —
                                        <t t-esc="this.formatH(state.selectedFaculty.orduak)"/>
                                    </span>
                                </div>
                                <div class="card-body p-0">
                                    <table class="table table-sm pfz-table mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Taldea</th>
                                                <th>Kurtsoa</th>
                                                <th>Kodea</th>
                                                <th>PT/PES</th>
                                                <th>Orduak</th>
                                                <th>Gela</th>
                                                <th>RPT</th>
                                                <th>Aste Ban.</th>
                                                <th>Zorretan</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.resumenModuluak" t-as="rm" t-key="rm.code + rm.batch">
                                                <tr>
                                                    <td class="text-muted"><t t-esc="rm.batch"/></td>
                                                    <td><t t-esc="rm.kurtsoa"/></td>
                                                    <td class="fw-semibold"><t t-esc="rm.code"/></td>
                                                    <td><t t-esc="rm.pt_pes"/></td>
                                                    <td><t t-esc="rm.orduak"/></td>
                                                    <td><t t-esc="rm.gela_orduak"/></td>
                                                    <td class="fw-semibold"><t t-esc="rm.rpt_total"/></td>
                                                    <td><t t-esc="rm.aste_banaketa"/></td>
                                                    <td><t t-esc="rm.orduak_zorretan"/></td>
                                                </tr>
                                            </t>
                                            <t t-foreach="state.karguak" t-as="k" t-key="'k' + k.id">
                                                <tr>
                                                    <td class="text-muted">—</td>
                                                    <td>—</td>
                                                    <td class="fw-semibold"><t t-esc="k.code"/></td>
                                                    <td>—</td>
                                                    <td>—</td>
                                                    <td>—</td>
                                                    <td class="fw-semibold"><t t-esc="k.orduak"/></td>
                                                    <td>—</td>
                                                    <td>—</td>
                                                </tr>
                                            </t>
                                            <t t-if="!state.resumenModuluak.length and !state.karguak.length">
                                                <tr>
                                                    <td colspan="9" class="text-center text-muted py-3 small">
                                                        Ez dago perfilaziorik.
                                                    </td>
                                                </tr>
                                            </t>
                                            <tr class="table-light fw-bold">
                                                <td colspan="3"></td>
                                                <td class="small">GUZTIRA</td>
                                                <td>—</td>
                                                <td><t t-esc="this.sumGela()"/></td>
                                                <td><t t-esc="this.sumRpt()"/></td>
                                                <td>—</td>
                                                <td><t t-esc="this.sumZorretan()"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </t>

                        </div>

                    </div>
                </t>

                <t t-if="!state.selectedMintegi">
                    <div class="text-muted text-center py-5">
                        <i class="fa fa-arrow-up me-1"/>Aukeratu mintegia goiko zerrendan.
                    </div>
                </t>

            </div>
        </div>
    </t>
</templates>
