<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="openeducat_hernani.FetTeacherUnavail">
        <div class="o_fet_unavail o_action">
            <div class="o_content p-3">

                <!-- Cabecera + selector de mintegi -->
                <div class="d-flex align-items-end gap-3 flex-wrap mb-3">
                    <h5 class="mb-0 text-uppercase fw-semibold text-muted me-2">
                        Irakasleen erabilgarritasuna
                    </h5>
                    <div>
                        <label class="form-label mb-0 small fw-semibold">Mintegia</label>
                        <select class="form-select form-select-sm"
                                t-on-change="onMintegiChange">
                            <option value="">— Aukeratu mintegia —</option>
                            <t t-foreach="state.mintegiak" t-as="m" t-key="m.id">
                                <option t-att-value="m.id"
                                        t-esc="m.name + (m.code ? ' (' + m.code + ')' : '')"/>
                            </t>
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-3 align-items-start">

                    <!-- Panel izquierdo: lista de irakasleak -->
                    <div class="feu-left border rounded p-2"
                         style="min-width: 280px; max-width: 320px;">
                        <div class="small fw-semibold text-muted mb-2">
                            Irakasleak
                            <span t-if="state.irakasleak.length"
                                  class="badge bg-secondary ms-1"
                                  t-esc="state.irakasleak.length"/>
                        </div>
                        <t t-if="!state.selectedMintegi">
                            <div class="text-muted small fst-italic">
                                Aukeratu mintegi bat hasteko.
                            </div>
                        </t>
                        <t t-else="">
                            <div t-foreach="state.irakasleak" t-as="f" t-key="f.id"
                                 class="feu-faculty px-2 py-1 rounded mb-1"
                                 t-att-class="state.selectedFaculty and state.selectedFaculty.id === f.id ? 'bg-primary text-white' : 'feu-faculty-hover'"
                                 style="cursor: pointer;"
                                 t-on-click="() => this.selectFaculty(f)">
                                <t t-esc="f.name"/>
                            </div>
                            <div t-if="!state.irakasleak.length"
                                 class="text-muted small fst-italic">
                                Mintegi honek ez du irakasle aktiborik.
                            </div>
                        </t>
                    </div>

                    <!-- Panel derecho: rejilla 5 días × Aste Saioak -->
                    <div class="feu-grid-wrap flex-grow-1">
                        <t t-if="!state.selectedFaculty">
                            <div class="text-muted fst-italic p-3">
                                Aukeratu irakasle bat ezkerrean, eta markatu hemen
                                klaserik EZIN duen franja.
                            </div>
                        </t>
                        <t t-else="">
                            <div class="mb-2">
                                <span class="fw-semibold" t-esc="state.selectedFaculty.name"/>
                                <span class="text-muted ms-2 small">
                                    (Markatuta: <t t-esc="unavailCount()"/> franja ez-erabilgarri)
                                </span>
                            </div>
                            <table class="table table-bordered feu-grid text-center mb-0">
                                <thead>
                                    <tr>
                                        <th class="feu-corner"></th>
                                        <th t-foreach="state.days" t-as="d" t-key="d.key"
                                            t-esc="d.label"/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="state.timings" t-as="t" t-key="t.id">
                                        <th class="feu-rowhead text-start" t-esc="t.name"/>
                                        <td t-foreach="state.days" t-as="d" t-key="d.key"
                                            class="feu-cell"
                                            t-att-class="isUnavail(d.key, t.id) ? 'feu-off' : 'feu-on'"
                                            style="cursor: pointer;"
                                            t-on-click="() => this.toggleCell(d.key, t.id)">
                                            <t t-if="isUnavail(d.key, t.id)">✕</t>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="small text-muted mt-2">
                                Klik egin franja batean markatzeko/kentzeko.
                                <span class="feu-legend feu-off ms-2"></span> = ez-erabilgarri ·
                                <span class="feu-legend feu-on ms-1"></span> = erabilgarri
                            </div>
                        </t>
                    </div>

                </div>
            </div>
        </div>
    </t>
</templates>
