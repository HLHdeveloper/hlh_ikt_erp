<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="openeducat_hernani.SisDashboard">
        <div class="o_sis_dashboard o_action">
            <div class="o_content p-4">

                <h5 class="mb-3 text-muted fw-semibold text-uppercase">Irakasleak</h5>

                <!-- Cards -->
                <div class="d-flex gap-3 flex-wrap mb-4">

                    <div t-attf-class="sdb-card{{ state.activeCard === 'total' ? ' sdb-card--active' : '' }}"
                         t-on-click="() => this.onCardClick('total')">
                        <div class="sdb-number" t-esc="state.counts.total"/>
                        <div class="sdb-label">Irakasleak</div>
                    </div>

                    <div t-attf-class="sdb-card{{ state.activeCard === 'funtzionarioa' ? ' sdb-card--active' : '' }}"
                         t-on-click="() => this.onCardClick('funtzionarioa')">
                        <div class="sdb-number" t-esc="state.counts.funtzionarioak"/>
                        <div class="sdb-label">Funtzionarioak</div>
                    </div>

                    <div t-attf-class="sdb-card{{ state.activeCard === 'ordezkoa' ? ' sdb-card--active' : '' }}"
                         t-on-click="() => this.onCardClick('ordezkoa')">
                        <div class="sdb-number" t-esc="state.counts.ordezkoak"/>
                        <div class="sdb-label">Ordezkoak</div>
                    </div>

                    <div t-attf-class="sdb-card sdb-card--warning{{ state.activeCard === 'bajan' ? ' sdb-card--active' : '' }}"
                         t-on-click="() => this.onCardClick('bajan')">
                        <div class="sdb-number" t-esc="state.counts.bajan"/>
                        <div class="sdb-label">Bajan daudenak</div>
                    </div>

                    <div t-attf-class="sdb-card{{ state.activeCard === 'karguak' ? ' sdb-card--active' : '' }}"
                         t-on-click="() => this.onCardClick('karguak')">
                        <div class="sdb-number" t-esc="state.counts.karguak"/>
                        <div class="sdb-label">Karguak</div>
                    </div>

                </div>

                <!-- Drill-down panel -->
                <div class="sdb-drilldown card shadow-sm" t-if="showDrilldown">
                    <div class="card-body">

                        <!-- Loading -->
                        <t t-if="state.loading">
                            <div class="text-center py-4">
                                <i class="fa fa-spinner fa-spin fa-2x text-muted"/>
                            </div>
                        </t>

                        <!-- Nivel 1: lista de mintegiak (todas las tarjetas) -->
                        <t t-elif="!state.selectedDept">
                            <h6 class="card-title mb-3" t-esc="state.drillTitle"/>
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Mintegia</th>
                                        <th class="text-end" style="width:70px">Kop.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.deptBreakdown" t-as="dept" t-key="dept.id">
                                        <tr class="sdb-dept-row" t-on-click="() => this.onDeptClick(dept)">
                                            <td><t t-esc="dept.name"/></td>
                                            <td class="text-end fw-semibold"><t t-esc="dept.count"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Nivel 2 BAJAN: titularrak bajan + ordezkoa + kopurua -->
                        <t t-elif="state.activeCard === 'bajan' &amp;&amp; !state.selectedBajanFaculty">
                            <div class="d-flex align-items-center mb-3">
                                <button class="btn btn-sm btn-outline-secondary me-2"
                                        t-on-click="() => this.backToDepts()">
                                    <i class="fa fa-arrow-left me-1"/>Mintegiak
                                </button>
                                <span class="fw-bold" t-esc="state.selectedDept.name"/>
                            </div>
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Titularra</th>
                                        <th>Ordezkoa</th>
                                        <th class="text-end" style="width:60px">Kop.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.facultyList" t-as="faculty" t-key="faculty.id">
                                        <tr class="sdb-faculty-row"
                                            t-on-click="() => this.onBajanTitularClick(faculty)">
                                            <td class="text-primary"><t t-esc="faculty.name"/></td>
                                            <td class="text-muted"><t t-esc="faculty.ordezko"/></td>
                                            <td class="text-end fw-semibold"><t t-esc="faculty.ordezko_count"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Nivel 3 BAJAN: historial de ordezkoak -->
                        <t t-elif="state.activeCard === 'bajan' &amp;&amp; state.selectedBajanFaculty">
                            <div class="d-flex align-items-center mb-3">
                                <button class="btn btn-sm btn-outline-secondary me-2"
                                        t-on-click="() => this.backToBajanFaculty()">
                                    <i class="fa fa-arrow-left me-1"/>Titularrak
                                </button>
                                <span class="fw-bold" t-esc="state.selectedBajanFaculty.name"/>
                            </div>
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ordezkoa</th>
                                        <th style="width:110px">Hasiera</th>
                                        <th style="width:110px">Bukaera</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.bajanHistory" t-as="h" t-key="h.id">
                                        <tr>
                                            <td><t t-esc="h.ordezko"/></td>
                                            <td class="text-muted"><t t-esc="h.start_date"/></td>
                                            <td>
                                                <t t-if="!h.end_date">
                                                    <button class="btn btn-sm btn-warning"
                                                            t-on-click.stop="() => this.onBukatuOrdezkapen(h)">
                                                        Bukatu ordezkapena
                                                    </button>
                                                </t>
                                                <t t-else="">
                                                    <span class="text-muted"><t t-esc="h.end_date"/></span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Nivel 2 KARGUAK: tipos de kargo -->
                        <t t-elif="state.activeCard === 'karguak' &amp;&amp; !state.selectedKarguType">
                            <div class="d-flex align-items-center mb-3">
                                <button class="btn btn-sm btn-outline-secondary me-2"
                                        t-on-click="() => this.backToDepts()">
                                    <i class="fa fa-arrow-left me-1"/>Mintegiak
                                </button>
                                <span class="fw-bold" t-esc="state.selectedDept.name"/>
                            </div>
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Kargo mota</th>
                                        <th class="text-end" style="width:70px">Kop.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.karguTypes" t-as="ktype" t-key="ktype.code">
                                        <tr class="sdb-dept-row" t-on-click="() => this.onKarguTypeClick(ktype)">
                                            <td><t t-esc="ktype.label"/></td>
                                            <td class="text-end fw-semibold"><t t-esc="ktype.count"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- Nivel 2/3: lista de irakasleak (total/funtz/ordezko/karguak) -->
                        <t t-else="">
                            <div class="d-flex align-items-center mb-3">
                                <t t-if="state.activeCard === 'karguak'">
                                    <button class="btn btn-sm btn-outline-secondary me-2"
                                            t-on-click="() => this.backToKarguTypes()">
                                        <i class="fa fa-arrow-left me-1"/>Kargu motak
                                    </button>
                                    <span class="fw-bold">
                                        <t t-esc="state.selectedDept.name"/> /
                                        <t t-esc="state.selectedKarguType.label"/>
                                    </span>
                                </t>
                                <t t-else="">
                                    <button class="btn btn-sm btn-outline-secondary me-2"
                                            t-on-click="() => this.backToDepts()">
                                        <i class="fa fa-arrow-left me-1"/>Mintegiak
                                    </button>
                                    <span class="fw-bold" t-esc="state.selectedDept.name"/>
                                </t>
                            </div>
                            <table class="table table-hover table-sm mb-0">
                                <thead t-if="state.selectedKarguType and state.selectedKarguType.type === 'tuto'"
                                       class="table-light">
                                    <tr>
                                        <th>Irakaslea</th>
                                        <th>Taldea</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.facultyList" t-as="faculty" t-key="faculty.id">
                                        <tr class="sdb-faculty-row" t-on-click="() => this.onFacultyClick(faculty)">
                                            <td><t t-esc="faculty.name"/></td>
                                            <td t-if="state.selectedKarguType and state.selectedKarguType.type === 'tuto'"
                                                class="text-muted">
                                                <t t-esc="faculty.kargu"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                    </div>
                </div>

            </div>
        </div>
    </t>
</templates>
